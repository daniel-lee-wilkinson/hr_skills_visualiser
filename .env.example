# Copy this file to .env and adjust values as needed.
# .env is excluded from version control – never commit real credentials.

# Path to the SQLite database file.
# Can be a filename relative to the project root, or an absolute path.
# Default (demo): skills_demo.db
# Production example: prod_skills.db
SKILLS_DB=skills_demo.db

# Optional: path to an additional .env file that overrides the local one.
# Useful for shared/production environments (replaces the old hard-coded P: drive path).
# Leave unset to use only the local .env above.
# SKILLS_ENV_PATH=C:\Skills_Tracker\.env
